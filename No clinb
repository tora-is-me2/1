-- ABRIR / FECHAR MENU
local aberto = false
BotaoAbrir.MouseButton1Click:Connect(function()
    TocarSom()
    aberto = not aberto
    if aberto then
        Menu.Visible = true
        TweenService:Create(Menu, ESTILO, {Size = TAMANHO_MENU, BackgroundTransparency = 0.1}):Play()
        BotaoAbrir.Text = "FECHAR"
    else
        TweenService:Create(Menu, ESTILO, {Size = TAMANHO_FECHADO, BackgroundTransparency = 1}):Play()
        task.wait(TEMPO_ANIMACAO)
        Menu.Visible = false
        BotaoAbrir.Text = "ABRIR"
    end
end)

-- MUDAR COR DA BORDA
local function MudarCor()
    indiceCor = indiceCor + 1
    if indiceCor > #cores.borda then indiceCor = 1 end
    Menu.BackgroundColor3 = cores.borda[indiceCor]
end

-- Clica longo para mudar cor
Menu.MouseButton1Down:Connect(function()
    task.wait(0.5)
    if aberto then MudarCor() end
end)
