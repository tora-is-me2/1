-- ==============================================
-- ✅ ATRAVESSAR OBJETOS / PAREDES
-- ==============================================
local function Atravessar(ativar)
    local char = Player.Character or Player.CharacterAdded:Wait()
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    
    if hrp then
        if ativar then
            -- Remove colisão
            hrp.CanCollide = false
            if hum then hum.Disabled = true end
        else
            -- Volta ao normal
            hrp.CanCollide = true
            if hum then hum.Disabled = false end
        end
    end
end

-- ==============================================
-- ✅ SISTEMA DE VELOCIDADE
-- ==============================================
RunService.RenderStepped:Connect(function()
    local char = Player.Character
    if not char then return end
    local hum = char:FindFirstChild("Humanoid")
    
    if velocidadeAtivada and hum then
        hum.WalkSpeed = VELOCIDADE_MAX
    else
        hum.WalkSpeed = VELOCIDADE_NORMAL
    end
    
    if atravessarAtivado then
        Atravessar(true)
    end
end)

